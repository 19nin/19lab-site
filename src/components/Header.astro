---
const navItems = [
  { label: 'Works', href: '/#works' },
  { label: 'About', href: '/#about' },
  { label: 'Contact', href: '/#contact' },
];
---

<header class="absolute top-0 left-0 right-0 z-30">
  <div class="max-w-7xl mx-auto px-6 sm:px-10 py-7 flex items-center justify-between">
    <a href="/" class="font-logo text-xl font-medium tracking-wider">
      <span>19lab</span>
    </a>
    <nav>
      <ul class="flex items-center gap-7 sm:gap-10 text-[11px] font-en tracking-[0.25em] uppercase text-ink-soft">
        {navItems.map((item) => (
          <li>
            <a
              href={item.href}
              class="hover:text-ink transition-colors duration-300"
            >
              {item.label}
            </a>
          </li>
        ))}
      </ul>
    </nav>
  </div>
</header>
