---
const year = new Date().getFullYear();

const navItems = [
  { label: 'Works', href: '/#works' },
  { label: 'About', href: '/#about' },
  { label: 'Contact', href: '/#contact' },
];
---

<footer class="bg-paper px-6 sm:px-10 py-12 border-t border-ink/10">
  <div class="max-w-7xl mx-auto">
    <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-8">
      <p class="font-logo text-xl font-medium tracking-wider">19lab</p>
      <ul class="flex flex-wrap items-center gap-7 sm:gap-10 text-[11px] font-en tracking-[0.25em] uppercase text-ink-soft">
        {navItems.map((item) => (
          <li>
            <a href={item.href} class="hover:text-ink transition-colors duration-300">
              {item.label}
            </a>
          </li>
        ))}
      </ul>
    </div>

    <div class="mt-10 pt-6 border-t border-ink/10 flex flex-col sm:flex-row sm:items-center sm:justify-between gap-3">
      <p class="text-[10px] font-en tracking-[0.3em] uppercase text-ink-muted">
        © {year} 19lab. All rights reserved.
      </p>
      <ul class="flex items-center gap-6 text-[10px] font-en tracking-[0.25em] uppercase text-ink-muted">
        <li><a href="/privacy" class="hover:text-ink transition-colors">Privacy</a></li>
        <li><a href="/terms" class="hover:text-ink transition-colors">Terms</a></li>
      </ul>
    </div>
  </div>
</footer>
