---
const year = new Date().getFullYear();
---

<footer class="bg-paper px-6 sm:px-10 py-12 border-t border-ink/10">
  <div class="max-w-7xl mx-auto">
    <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-8">
      <p class="font-display text-2xl tracking-wide">19lab</p>
      <ul class="flex flex-wrap items-center gap-5 sm:gap-7 text-[10px] font-en tracking-[0.25em] uppercase text-ink-muted">
        <li><a href="#works" class="hover:text-ink transition-colors">Works</a></li>
        <li><a href="#about" class="hover:text-ink transition-colors">About</a></li>
        <li><a href="#contact" class="hover:text-ink transition-colors">Contact</a></li>
        <li><a href="/privacy" class="hover:text-ink transition-colors">Privacy</a></li>
        <li><a href="/terms" class="hover:text-ink transition-colors">Terms</a></li>
      </ul>
    </div>

    <p class="mt-8 pt-6 border-t border-ink/10 text-[10px] font-en tracking-[0.3em] uppercase text-ink-muted">
      © {year} 19lab. All rights reserved.
    </p>
  </div>
</footer>
