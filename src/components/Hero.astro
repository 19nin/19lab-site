---
---

<section class="relative w-full min-h-[88vh] flex flex-col">
  <div class="absolute inset-0 z-0">
    <video
      src="/videos/hero-leaf.mp4"
      poster="/images/hero-leaf.jpg"
      autoplay
      muted
      loop
      playsinline
      preload="metadata"
      class="w-full h-full object-cover brightness-90"
    ></video>
    <div class="absolute inset-0 bg-ink/10 mix-blend-multiply"></div>
    <div class="absolute inset-0 bg-paper-warm/20 mix-blend-soft-light"></div>
    <div class="absolute inset-x-0 top-0 h-32 bg-gradient-to-b from-ink/40 to-transparent pointer-events-none"></div>
    <div class="absolute inset-0 bg-gradient-to-t from-paper via-paper/80 to-transparent"></div>
    <div class="absolute inset-x-0 bottom-0 h-2/3 bg-gradient-to-t from-paper to-transparent"></div>
  </div>

  <div class="relative z-10 flex-1 flex items-end pb-20 sm:pb-24 pt-32 px-6 sm:px-10">
    <div class="max-w-7xl mx-auto w-full">
      <p class="font-en text-[11px] tracking-[0.3em] uppercase text-ink-soft mb-7 fade-in">
        Indie Studio · Tokyo
      </p>

      <h1 class="font-display font-semibold text-4xl sm:text-6xl md:text-7xl leading-[1.5] tracking-wide max-w-4xl text-ink fade-in">
        くらしに、ちいさな灯を。
      </h1>

      <p class="mt-8 sm:mt-10 text-base sm:text-lg text-ink-soft max-w-xl leading-loose fade-in">
        日々のための、やさしいプロダクトをつくっています。
      </p>
    </div>
  </div>
</section>
